# Reference only — all settings are configured through the Settings UI.
# Delete this file if you don't want a local .env.
# Defaults (no file needed): PORT=3000, DATA_DIR=./data, AI_PROVIDER=offline

PORT=4173
DATA_DIR=./data
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id
NOTION_TOPIC_PROPERTY=Topic
NOTION_TOPIC_FILTERS=
AI_PROVIDER=openai-compatible
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini

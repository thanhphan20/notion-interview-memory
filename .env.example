# Reference only — all settings are configured through the Settings UI.
# Delete this file if you don't want a local .env.
# Defaults (no file needed): PORT=3000, DATA_DIR=./data, AI_PROVIDER=offline

PORT=4173
DATA_DIR=./data
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id
NOTION_TOPIC_PROPERTY=Topic
NOTION_TOPIC_FILTERS=
# AI_PROVIDER options: offline | groq | openrouter | gemini | openai | openai-compatible
# Free tiers: groq, openrouter (:free models), gemini.
# Base URL / model are optional — each provider has sensible defaults.
#   groq        -> https://api.groq.com/openai/v1
#   openrouter  -> https://openrouter.ai/api/v1
#   gemini      -> https://generativelanguage.googleapis.com/v1beta/openai
#   openai      -> https://api.openai.com/v1 (ChatGPT / OpenAI API)
# openai-compatible is the same OpenAI API by default too, but meant for
# pointing AI_BASE_URL at a different (self-hosted or third-party) endpoint.
# Fallback providers (tried in order if the primary fails/rate-limits) are
# configured only via the Settings UI ("Fallback providers" section), since
# env vars can't express a list of provider configs.
AI_PROVIDER=openai-compatible
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
